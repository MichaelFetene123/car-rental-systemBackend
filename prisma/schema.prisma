generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name        String            @db.VarChar(120)
  email            String            @unique @db.VarChar(255)
  password         String            @db.VarChar(255)
  phone            String?           @db.VarChar(30)
  status           String            @default("active") @db.VarChar(20)
  total_bookings   Int?              @default(0)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @default(now())
  bookings         Booking[]
  notificationLogs NotificationLog[]
  userRoles        UserRole[]

  @@index([status], map: "idx_users_status")
  @@map("users")
}

model Role {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String           @unique @db.VarChar(50)
  created_at      DateTime         @default(now())
  type            RoleType         @default(user)
  updated_at      DateTime         @default(now())
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([type], map: "idx_roles_type")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamp(6)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relatBookingStatus ion(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Permission {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String           @unique @db.VarChar(80)
  name            String           @db.VarChar(120)
  category        String           @db.VarChar(60)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Location {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String    @db.VarChar(120)
  address          String    @db.VarChar(255)
  city             String    @db.VarChar(100)
  state            String    @db.VarChar(100)
  zipCode          String    @map("zip_code") @db.VarChar(20)
  phone            String?   @db.VarChar(30)
  email            String?   @db.VarChar(255)
  openingHours     String?   @map("opening_hours") @db.VarChar(255)
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  bookingsAsPickup Booking[] @relation("pickup")
  bookingsAsReturn Booking[] @relation("return")
  cars             Car[]

  @@unique([name, city, state])
  @@index([isActive], map: "idx_locations_active")
  @@index([city, state], map: "idx_locations_city_state")
  @@map("locations")
}

model CarCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(60)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  updatedAt   DateTime @default(now()) @map("last_updated") @db.Timestamp(6)
  cars        Car[]

  @@index([name], map: "idx_categories_name")
  @@map("car_categories")
}

model Car {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String       @db.VarChar(120)
  categoryId     String?      @map("category_id") @db.Uuid
  year           Int          @db.SmallInt
  seats          Int          @db.SmallInt
  fuelType       String?      @map("fuel_type") @db.VarChar(40)
  transmission   String       @db.VarChar(40)
  pricePerDay    Decimal      @map("price_per_day") @db.Decimal(10, 2)
  status         CarStatus    @default(available)
  imageUrl       String?      @map("image_url")
  description    String?
  homeLocationId String?      @map("home_location_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamp(6)
  bookings       Booking[]
  category       CarCategory? @relation(fields: [categoryId], references: [id])
  homeLocation   Location?    @relation(fields: [homeLocationId], references: [id])

  @@index([status], map: "idx_cars_status")
  @@index([categoryId], map: "idx_cars_category")
  @@index([homeLocationId], map: "idx_cars_home_location")
  @@index([pricePerDay], map: "idx_cars_price")
  @@map("cars")
}

model Booking {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingCode      String            @unique @map("booking_code") @db.VarChar(40)
  userId           String            @map("user_id") @db.Uuid
  carId            String            @map("car_id") @db.Uuid
  pickupLocationId String?           @map("pickup_location_id") @db.Uuid
  returnLocationId String?           @map("return_location_id") @db.Uuid
  pickupAt         DateTime          @map("pickup_at") @db.Timestamp(6)
  returnAt         DateTime          @map("return_at") @db.Timestamp(6)
  status           BookingStatus
  totalAmount      Decimal           @map("total_amount") @db.Decimal(10, 2)
  bookedAt         DateTime          @default(now()) @map("booked_at") @db.Timestamp(6)
  carNameSnapshot  String?           @map("car_name_snapshot") @db.VarChar(120)
  carTypeSnapshot  String?           @map("car_type_snapshot") @db.VarChar(60)
  carYearSnapshot  Int?              @map("car_year_snapshot") @db.SmallInt
  carImageSnapshot String?           @map("car_image_snapshot")
  car              Car               @relation(fields: [carId], references: [id])
  pickupLocation   Location?         @relation("pickup", fields: [pickupLocationId], references: [id])
  returnLocation   Location?         @relation("return", fields: [returnLocationId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  notificationLogs NotificationLog[]
  payments         Payment[]

  @@index([userId, bookedAt], map: "idx_bookings_user_time")
  @@index([carId, pickupAt, returnAt], map: "idx_bookings_car_dates")
  @@index([status], map: "idx_bookings_status")
  @@map("bookings")
}

model Payment {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId     String        @map("booking_id") @db.Uuid
  invoiceNumber String        @unique @map("invoice_number") @db.VarChar(40)
  transactionId String?       @unique @map("transaction_id") @db.VarChar(80)
  amount        Decimal       @db.Decimal(10, 2)
  tax           Decimal       @default(0) @db.Decimal(10, 2)
  fees          Decimal       @default(0) @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus
  paidAt        DateTime?     @map("paid_at") @db.Timestamp(6)
  refundReason  String?       @map("refund_reason")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId], map: "idx_payments_booking")
  @@index([status], map: "idx_payments_status")
  @@index([paidAt], map: "idx_payments_paid_at")
  @@map("payments")
}

model NotificationTemplate {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String                   @db.VarChar(120)
  type             NotificationTemplateType
  trigger_event    String                   @db.VarChar(80)
  subject          String?                  @db.VarChar(255)
  content          String
  enabled          Boolean                  @default(true)
  created_at       DateTime                 @default(now()) @db.Timestamp(6)
  updated_at       DateTime                 @default(now()) @db.Timestamp(6)
  notificationLogs NotificationLog[]

  @@map("notification_templates")
}

model NotificationLog {
  id                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  template_id          String?                  @db.Uuid
  user_id              String?                  @db.Uuid
  booking_id           String?                  @db.Uuid
  type                 NotificationTemplateType
  recipient            String                   @db.VarChar(255)
  subject              String?                  @db.VarChar(255)
  status               NotificationLogStatus
  sent_at              DateTime                 @default(now()) @db.Timestamp(6)
  error_message        String?
  booking              Booking?                 @relation(fields: [booking_id], references: [id])
  notificationTemplate NotificationTemplate?    @relation(fields: [template_id], references: [id])
  user                 User?                    @relation(fields: [user_id], references: [id])

  @@index([status], map: "idx_notif_logs_status")
  @@index([sent_at], map: "idx_notif_logs_sent_at")
  @@map("notification_logs")
}

model NotificationChannelSettings {
  id          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channel     NotificationTemplateType @unique
  provider    String                   @db.VarChar(80)
  config_json Json                     @default("{}")
  from_name   String?                  @db.VarChar(120)
  from_email  String?                  @db.VarChar(255)
  from_number String?                  @db.VarChar(30)
  is_active   Boolean                  @default(true)
  updated_at  DateTime                 @default(now()) @db.Timestamp(6)

  @@map("notification_channel_settings")
}

enum RoleType {
  admin
  stuff
  user

  @@map("role_type")
}

enum CarStatus {
  available
  rented
  maintenance

  @@map("car_status")
}

enum BookingStatus {
  pending
  approved
  rejected
  cancelled
  completed
}

enum PaymentMethod {
  credit_card
  mobile_money
  cash
}

enum PaymentStatus {
  pending
  completed
  refunded
  failed
}

enum NotificationTemplateType {
  email
  sms
}

enum NotificationLogStatus {
  sent
  failed
  pending
}
